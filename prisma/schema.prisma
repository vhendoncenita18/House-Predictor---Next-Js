// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid()) // Changed from Int to String
  firstName     String
  middleName    String?
  lastName      String
  gender        String
  birthdate     DateTime
  username      String    @unique
  avatarUrl     String?
  password      String 
  utype         String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relationship link
  predictions   Prediction[]

  @@map("users") 
}

model Prediction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  userId          String   @map("user_id") 
  // ONLY KEEP THIS ONE LINE FOR THE RELATION:
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  location        String
  propertyType    String   @map("property_type")
  lotArea         Decimal? @map("lot_area") @db.Decimal
  floorArea       Decimal  @map("floor_area") @db.Decimal
  bedrooms        Int?
  bathrooms       Int?
  kitchens        Int?
  garages         Int?
  predictedPrice  Decimal  @map("predicted_price") @db.Decimal

  @@map("predictions")
}
